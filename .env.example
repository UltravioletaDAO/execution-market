# =============================================================================
# Chamba Environment Variables
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# For Docker development, you can also use:
#   cp .env.docker.example .env  (includes demo Supabase keys)
#
# NEVER commit .env to git - it contains secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
# development | staging | production
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# DATABASE (Supabase / PostgreSQL)
# -----------------------------------------------------------------------------
# Local development uses Docker Compose services
# Production should use Supabase Cloud or managed PostgreSQL

# PostgreSQL password (used by Docker Compose)
POSTGRES_PASSWORD=postgres

# JWT secret for Supabase Auth (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Secret key base for Realtime (min 64 characters)
# Generate with: openssl rand -base64 64
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# Supabase connection
# Local: http://localhost:54321 (PostgREST via Docker)
# Cloud: https://[project-ref].supabase.co
SUPABASE_URL=http://localhost:54321

# Supabase anonymous key (public, safe to expose to frontend)
# Generate at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Supabase service key (private, server-side only)
# Generate at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_KEY=YOUR_SERVICE_KEY_HERE

# -----------------------------------------------------------------------------
# BLOCKCHAIN (x402 / Ethereum)
# -----------------------------------------------------------------------------
# x402 facilitator for instant payments
X402_FACILITATOR_URL=https://facilitator.ultravioleta.xyz

# RPC endpoint for blockchain interactions
# Local (Anvil): http://localhost:8545
# Base Mainnet: https://mainnet.base.org
# Base Sepolia: https://sepolia.base.org
X402_RPC_URL=http://localhost:8545

# Private key for server-side transactions
# NEVER commit this! Use secrets manager in production.
# For local development, use one of Anvil's test accounts:
# ANVIL_TEST_KEY_REMOVED
X402_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# Chain ID
# Local (Anvil): 31337
# Base Mainnet: 8453
# Base Sepolia: 84532
CHAIN_ID=31337

# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------
# Anthropic Claude API (for AI verification)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_API_KEY_HERE

# OpenAI API (optional, for embeddings/fallback)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_API_KEY_HERE

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
# Pinata IPFS for decentralized evidence storage
# Get JWT at: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=YOUR_JWT_HERE

# Supabase Storage URL (local)
STORAGE_URL=http://localhost:54325

# Anvil RPC URL for frontend
VITE_ANVIL_RPC_URL=http://localhost:8545

# -----------------------------------------------------------------------------
# REDIS (Caching & Rate Limiting)
# -----------------------------------------------------------------------------
# Local development
REDIS_URL=redis://localhost:6379/0

# Production (use managed Redis like Upstash)
# REDIS_URL=redis://default:password@host:6379/0

# -----------------------------------------------------------------------------
# WEBHOOKS
# -----------------------------------------------------------------------------
# Secret for signing webhook payloads
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# -----------------------------------------------------------------------------
# FRONTEND (Vite Environment Variables)
# -----------------------------------------------------------------------------
# These are baked into the frontend at build time
# Prefix with VITE_ to expose to frontend

# Supabase connection for frontend
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# API server URL
VITE_API_URL=http://localhost:8000

# WalletConnect project ID
# Get at: https://cloud.walletconnect.com/
VITE_WALLET_CONNECT_PROJECT_ID=YOUR_PROJECT_ID_HERE

# Chain ID for frontend
VITE_CHAIN_ID=31337

# -----------------------------------------------------------------------------
# MONITORING (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
# SENTRY_DSN=https://key@sentry.io/project

# Datadog API key
# DD_API_KEY=YOUR_API_KEY_HERE

# -----------------------------------------------------------------------------
# FEATURE FLAGS (Optional)
# -----------------------------------------------------------------------------
# Enable/disable features
ENABLE_AI_VERIFICATION=true
ENABLE_DISPUTE_ARBITRATION=true
ENABLE_SUPERFLUID_STREAMING=false
ENABLE_ERC8004_INTEGRATION=true

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
# Requests per minute per IP
RATE_LIMIT_RPM=60

# Burst limit
RATE_LIMIT_BURST=10

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# TESTING (Development Only)
# -----------------------------------------------------------------------------
# Anvil test accounts (never use in production!)
# Account 0: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
# Private Key: ANVIL_TEST_KEY_REMOVED

# Test mode bypasses certain verifications
# TEST_MODE=true
