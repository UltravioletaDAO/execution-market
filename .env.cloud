# =============================================================================
# Execution Market - Cloud Development Environment
# =============================================================================
# Usa Supabase Cloud + servicios locales mínimos
# Más rápido y confiable que montar stack completo
#
# Copy to .env:
#   cp .env.cloud .env
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# SUPABASE (Cloud - Producción)
# -----------------------------------------------------------------------------
# Usando Supabase Cloud para evitar complejidad de stack local
SUPABASE_URL=https://puyhpytmtkyevnxffksl.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InB1eWhweXRtdGt5ZXZueGZma3NsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MzYzNzkxMDgsImV4cCI6MjA1MTk1NTEwOH0.qOdNFKHiF2FpY4iGTCjSqRXLUtmhTdlLrU7hzzYYJ7Q

# Service key - PIDE AL ADMIN (no commitear)
SUPABASE_SERVICE_KEY=YOUR_SERVICE_KEY_HERE

# Frontend
VITE_SUPABASE_URL=https://puyhpytmtkyevnxffksl.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InB1eWhweXRtdGt5ZXZueGZma3NsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MzYzNzkxMDgsImV4cCI6MjA1MTk1NTEwOH0.qOdNFKHiF2FpY4iGTCjSqRXLUtmhTdlLrU7hzzYYJ7Q

# -----------------------------------------------------------------------------
# BLOCKCHAIN / x402
# -----------------------------------------------------------------------------
# Anvil local (chain ID 31337)
CHAIN_ID=31337
VITE_CHAIN_ID=31337
X402_RPC_URL=http://localhost:8545
VITE_ANVIL_RPC_URL=http://localhost:8545

# x402 Facilitator (producción)
X402_FACILITATOR_URL=https://facilitator.ultravioletadao.xyz
X402_NETWORK=base

# Private key - Anvil test account #0
X402_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------
# Agrega tus API keys aquí
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
PINATA_JWT=

# -----------------------------------------------------------------------------
# WALLET PROVIDERS (Frontend)
# -----------------------------------------------------------------------------
# Dynamic.xyz - PIDE AL ADMIN
VITE_DYNAMIC_ENVIRONMENT_ID=YOUR_DYNAMIC_ENV_ID_HERE

# WalletConnect (opcional)
VITE_WALLET_CONNECT_PROJECT_ID=

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_AI_VERIFICATION=true
ENABLE_ERC8004_INTEGRATION=true
EM_ENABLED_NETWORKS=base,base-sepolia
EM_PLATFORM_FEE=0.08

# ERC-8004 Identity
ERC8004_NETWORK=base
EM_AGENT_ID=2106

# Agent mutations
VITE_REQUIRE_AGENT_API_KEY=false
VITE_ALLOW_DIRECT_SUPABASE_MUTATIONS=true

# -----------------------------------------------------------------------------
# FRONTEND URLs
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
