# =============================================================================
# Execution Market Docker Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.docker.example .env
#
# NEVER commit .env to git - it contains secrets!
#
# For Docker Compose usage. All services use these environment variables.
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# POSTGRESQL / SUPABASE DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL password (used by all Supabase services)
POSTGRES_PASSWORD=postgres

# JWT secret for Supabase Auth (minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Secret key base for Realtime (minimum 64 characters)
# Generate with: openssl rand -base64 64
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq

# -----------------------------------------------------------------------------
# SUPABASE API KEYS
# -----------------------------------------------------------------------------
# These are JWT tokens. For local development, you can use the demo keys below.
# For production, generate new keys at: https://supabase.com/dashboard/project/_/settings/api
#
# Demo ANON key (public, safe for frontend):
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Demo SERVICE_ROLE key (private, server-side only):
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Frontend uses these (same as above, but VITE_ prefix for Vite):
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# -----------------------------------------------------------------------------
# BLOCKCHAIN / x402
# -----------------------------------------------------------------------------
# Chain ID (31337 = Anvil local, 8453 = Base Mainnet, 84532 = Base Sepolia)
CHAIN_ID=31337
VITE_CHAIN_ID=31337

# RPC URL (local Anvil by default, containers use internal URL)
X402_RPC_URL=http://anvil:8545
VITE_ANVIL_RPC_URL=http://localhost:8545

# x402 Facilitator URL
X402_FACILITATOR_URL=https://facilitator.ultravioleta.xyz

# Private key for server-side transactions
# For local development, use Anvil's default account #0:
# Address: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
X402_PRIVATE_KEY=ANVIL_TEST_KEY_REMOVED

# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------
# Anthropic Claude API (for AI verification)
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API (optional, for embeddings/fallback)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
# Pinata IPFS for decentralized evidence storage
# Get JWT at: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=

# -----------------------------------------------------------------------------
# WEBHOOKS
# -----------------------------------------------------------------------------
# Secret for signing webhook payloads
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your-webhook-secret-here

# -----------------------------------------------------------------------------
# WALLETCONNECT (Frontend)
# -----------------------------------------------------------------------------
# WalletConnect project ID for wallet connection
# Get at: https://cloud.walletconnect.com/
VITE_WALLET_CONNECT_PROJECT_ID=

# -----------------------------------------------------------------------------
# SERVICE URLS (Internal Docker network)
# -----------------------------------------------------------------------------
# These are set by docker-compose but can be overridden
VITE_SUPABASE_URL=http://localhost:54321
VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_AI_VERIFICATION=true
ENABLE_DISPUTE_ARBITRATION=true
ENABLE_SUPERFLUID_STREAMING=false
ENABLE_ERC8004_INTEGRATION=true

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# =============================================================================
# QUICK START
# =============================================================================
# 1. Copy this file: cp .env.docker.example .env
# 2. The defaults work for local development with Anvil
# 3. Add your API keys (ANTHROPIC_API_KEY, etc.) for full functionality
# 4. Run: make up
#
# Services will be available at:
#   - Dashboard:        http://localhost:5173
#   - MCP Server:       http://localhost:8000
#   - Supabase API:     http://localhost:54321
#   - Supabase Studio:  http://localhost:54322
#   - Email Testing:    http://localhost:54323
#   - PostgreSQL:       localhost:54320
#   - Anvil RPC:        http://localhost:8545
#   - Redis:            localhost:6379
# =============================================================================
