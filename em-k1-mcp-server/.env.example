# ============================================================
# em-k1-mcp-server — example environment configuration
# ============================================================
# Copy this file to `.env` and fill in your values.
# NEVER commit a populated .env file. All real secrets must
# stay in .env (gitignored) or AWS Secrets Manager.
# ============================================================

# ---- Booster K1 robot ----
# IP/hostname of the K1 on your LAN (only used when K1_BACKEND=hardware)
K1_HOST=192.168.1.50
# Backend implementation: mock | isaac_sim | hardware
K1_BACKEND=mock
# Soft motion cap — overrides any tool requesting higher speeds
K1_MAX_LINEAR_VELOCITY_MPS=0.6
K1_MAX_ANGULAR_VELOCITY_RPS=0.8
K1_MAX_GRIP_FORCE_N=40.0

# ---- Vision / observation ----
# Caption model used by k1_observe() to describe camera frames.
K1_VISION_MODEL=claude-opus-4-7
# Local directory where observation frames are written.
K1_CAPTURE_DIR=./captures

# ---- Execution Market integration ----
EM_API_URL=https://api.execution.market
# Path to an OWS-encrypted keystore — replace with your real path.
# NEVER paste a private key directly in this file.
EM_WALLET_KEY_PATH=YOUR_KEYSTORE_PATH_HERE
# Optional ERC-8004 agent ID — leave blank to auto-register on first task.
EM_AGENT_ID=
# Worker identity hint used in submitted evidence metadata.
EM_WORKER_NAME=k1-executor

# ---- Logging ----
LOG_LEVEL=INFO
