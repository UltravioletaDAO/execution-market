# NOTE: All production contracts (ERC-8004, x402r, PaymentOperator) are already
# deployed on mainnet. This file is only needed if deploying NEW operator instances
# or for local development with Hardhat/Foundry.
# See CLAUDE.md "On-Chain Contracts" table for deployed addresses.

# ============================================================
# Execution Market Contracts Deployment Configuration
# Aligned with x402 facilitator supported networks
# ============================================================

# Private key for deployment (with 0x prefix)
DEPLOYER_PRIVATE_KEY=

# ============================================================
# RPC URLs (optional - defaults provided)
# ============================================================

# Ethereum
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ETHEREUM_SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Base
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Avalanche
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Optimism
OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

# Arbitrum
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Celo
CELO_RPC_URL=https://forno.celo.org
CELO_ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# BSC
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Scroll
SCROLL_RPC_URL=https://rpc.scroll.io
SCROLL_SEPOLIA_RPC_URL=https://sepolia-rpc.scroll.io

# ============================================================
# Block Explorer API Keys (for contract verification)
# ============================================================

ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
SNOWTRACE_API_KEY=
POLYGONSCAN_API_KEY=
OPTIMISM_API_KEY=
ARBISCAN_API_KEY=
CELOSCAN_API_KEY=
BSCSCAN_API_KEY=
SCROLLSCAN_API_KEY=

# ============================================================
# Other
# ============================================================
REPORT_GAS=false
