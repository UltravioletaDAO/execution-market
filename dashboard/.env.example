# =============================================================================
# Execution Market Dashboard Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# These variables are baked into the build at compile time.
# Changes require rebuilding the application.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Local development (Docker Compose)
VITE_SUPABASE_URL=http://localhost:54321

# Production (Supabase Cloud)
# VITE_SUPABASE_URL=https://[project-ref].supabase.co

# Anonymous key (public, safe to expose)
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# MCP Server URL
# Local development
VITE_API_URL=http://localhost:8000

# Production
# VITE_API_URL=https://api.execution.market

# -----------------------------------------------------------------------------
# Blockchain Configuration
# -----------------------------------------------------------------------------
# Chain ID for wallet connections
# Local (Anvil): 31337
# Base Mainnet: 8453
# Base Sepolia: 84532
VITE_CHAIN_ID=31337

# -----------------------------------------------------------------------------
# Wallet Providers
# -----------------------------------------------------------------------------
# WalletConnect (get at https://cloud.walletconnect.com)
VITE_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# Crossmint Email Wallets (optional)
# Enables users to create wallets with just their email
# Get at: https://crossmint.com/console
VITE_CROSSMINT_PROJECT_ID=your-crossmint-project-id

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features at build time
VITE_ENABLE_TESTNET=true
VITE_ENABLE_EMAIL_WALLETS=false
VITE_ENABLE_STREAMING_PAYMENTS=false

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
# Enable mock data for development
# VITE_MOCK_MODE=true

# Debug mode (verbose logging)
# VITE_DEBUG=true
