# =============================================================================
# Execution Market Dashboard Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# These variables are baked into the build at compile time.
# Changes require rebuilding the application.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Local development (Docker Compose)
VITE_SUPABASE_URL=http://localhost:54321

# Production (Supabase Cloud)
# VITE_SUPABASE_URL=https://[project-ref].supabase.co

# Anonymous key (public, safe to expose)
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# MCP Server URL
# Local development
VITE_API_URL=http://localhost:8000

# Production
# VITE_API_URL=https://api.execution.market

# Evidence upload API (enables S3 presigned URL pipeline instead of Supabase Storage)
# VITE_EVIDENCE_API_URL=https://api.execution.market/api/v1/evidence

# Wallet USDC balances Lambda (ADR-001 wallet panel on /profile).
# Public Function URL backed by private QuikNode RPCs in `facilitator-rpc-mainnet`.
# When unset, the WalletSection falls back to direct viem reads against public
# RPCs, which get rate-limited under load. Output of `terraform apply`:
#   `terraform output em_balances_lambda_url`
# VITE_BALANCES_LAMBDA_URL=https://<id>.lambda-url.us-east-2.on.aws

# -----------------------------------------------------------------------------
# Blockchain Configuration
# -----------------------------------------------------------------------------
# Wallet Providers
# -----------------------------------------------------------------------------
# Dynamic.xyz - Wallet authentication (get at https://app.dynamic.xyz)
# This is the primary auth provider
VITE_DYNAMIC_ENVIRONMENT_ID=your-dynamic-environment-id

# -----------------------------------------------------------------------------
# Auth Contract (Agent Mutation Guards)
# -----------------------------------------------------------------------------
# Agent mutations (create task, approve, reject, cancel) go through the REST
# API. Authentication is either Supabase JWT (for signed-in humans) or
# ERC-8128 wallet signature (for external agents). VITE_API_KEY was removed
# in Phase 4.4 — a public-bundle secret is not a secret. Do NOT reintroduce.
VITE_REQUIRE_AGENT_API_KEY=false
# VITE_ALLOW_DIRECT_SUPABASE_MUTATIONS removed — DB-008 security lockdown.
# All mutations now go through the backend API exclusively.

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features at build time
VITE_ENABLE_TESTNET=true
# Note: Email login is configured in Dynamic Dashboard (app.dynamic.xyz), not via env vars

# World ID (proof-of-humanity) visibility in the profile UI.
# When unset or "false", the World ID card is hidden from the profile
# completion modal and the profile page. Backend enforcement is still
# controlled independently by `EM_WORLD_ID_ENABLED` on the MCP server.
VITE_WORLD_ID_ENABLED=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# Sentry DSN for the frontend (Task 1.6 — SaaS Production Hardening).
# When empty/unset, Sentry is NOT initialized and the app works normally.
# The ErrorBoundary still captures render errors — it just won't report them.
# Get a DSN at https://sentry.io → Projects → Client Keys (DSN).
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
# E2E testing escape hatch (set to "true" to bypass auth in E2E tests)
VITE_E2E_MODE=
