# =============================================================================
# Execution Market Dashboard Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# These variables are baked into the build at compile time.
# Changes require rebuilding the application.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Local development (Docker Compose)
VITE_SUPABASE_URL=http://localhost:54321

# Production (Supabase Cloud)
# VITE_SUPABASE_URL=https://[project-ref].supabase.co

# Anonymous key (public, safe to expose)
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# MCP Server URL
# Local development
VITE_API_URL=http://localhost:8000

# Production
# VITE_API_URL=https://api.execution.market

# Evidence upload API (enables S3 presigned URL pipeline instead of Supabase Storage)
# VITE_EVIDENCE_API_URL=https://api.execution.market/api/v1/evidence

# -----------------------------------------------------------------------------
# Blockchain Configuration
# -----------------------------------------------------------------------------
# Chain ID for wallet connections
# Local (Anvil): 31337
# Base Mainnet: 8453
# Base Sepolia: 84532
VITE_CHAIN_ID=31337

# -----------------------------------------------------------------------------
# Wallet Providers
# -----------------------------------------------------------------------------
# Dynamic.xyz - Wallet authentication (get at https://app.dynamic.xyz)
# This is the primary auth provider
VITE_DYNAMIC_ENVIRONMENT_ID=your-dynamic-environment-id

# WalletConnect (get at https://cloud.walletconnect.com)
# Optional: only needed if not using Dynamic
VITE_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# -----------------------------------------------------------------------------
# Auth Contract (Agent Mutation Guards)
# -----------------------------------------------------------------------------
# When true, agent mutations (create task, approve, reject, cancel) require
# an API key and go through the REST API instead of direct Supabase writes.
VITE_REQUIRE_AGENT_API_KEY=false
VITE_ALLOW_DIRECT_SUPABASE_MUTATIONS=true

# API key for agent operations (required when VITE_REQUIRE_AGENT_API_KEY=true)
# VITE_API_KEY=em_your_agent_api_key_here

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features at build time
VITE_ENABLE_TESTNET=true
VITE_ENABLE_EMAIL_WALLETS=false
VITE_ENABLE_STREAMING_PAYMENTS=false

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------
# Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel
# VITE_MIXPANEL_TOKEN=your-mixpanel-token

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
# Enable mock data for development
# VITE_MOCK_MODE=true

# Debug mode (verbose logging)
# VITE_DEBUG=true

# E2E testing escape hatch (set to "true" to bypass auth in E2E tests)
VITE_E2E_MODE=
