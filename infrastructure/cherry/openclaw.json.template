{
  "$comment": "Karma Kadabra V2 — OpenClaw Gateway Configuration (Task 3.5). Generated by generate-openclaw-config.py. Do NOT edit manually.",

  "gateway": {
    "bind": "127.0.0.1",
    "port": 18789,
    "hotReload": "hybrid"
  },

  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspaces",
      "model": "anthropic/claude-haiku-4-5"
    },
    "list": [
      {
        "id": "kk-coordinator",
        "workspace": "~/.openclaw/workspaces/kk-coordinator",
        "model": "anthropic/claude-sonnet-4-5",
        "default": true
      },
      {
        "id": "kk-karma-hello",
        "workspace": "~/.openclaw/workspaces/kk-karma-hello",
        "model": "anthropic/claude-haiku-4-5"
      },
      {
        "id": "kk-skill-extractor",
        "workspace": "~/.openclaw/workspaces/kk-skill-extractor",
        "model": "anthropic/claude-haiku-4-5"
      },
      {
        "id": "kk-voice-extractor",
        "workspace": "~/.openclaw/workspaces/kk-voice-extractor",
        "model": "anthropic/claude-haiku-4-5"
      },
      {
        "id": "kk-validator",
        "workspace": "~/.openclaw/workspaces/kk-validator",
        "model": "anthropic/claude-sonnet-4-5"
      }
    ],
    "bindings": [
      {
        "agentId": "kk-coordinator",
        "match": { "channel": "irc", "channelName": "#kk-ops" }
      },
      {
        "agentId": "kk-karma-hello",
        "match": { "channel": "irc", "channelName": "#kk-data-market" }
      }
    ]
  },

  "channels": {
    "irc": {
      "enabled": true,
      "accounts": {
        "swarm": {
          "server": "irc.meshrelay.xyz",
          "port": 6667,
          "channels": ["#Agents", "#kk-ops", "#kk-data-market"],
          "nick": "kk-swarm-${SERVER_INDEX}"
        }
      }
    }
  },

  "models": {
    "primary": "anthropic/claude-haiku-4-5",
    "fallback": ["anthropic/claude-sonnet-4-5"]
  },

  "mcp": {
    "servers": [
      {
        "name": "execution-market",
        "type": "http",
        "url": "https://mcp.execution.market/mcp/",
        "timeout": 60
      }
    ]
  },

  "sessions": {
    "scope": "per-channel-peer",
    "ttl": 86400
  },

  "logging": {
    "level": "info",
    "file": "~/.openclaw/logs/gateway.log"
  }
}
