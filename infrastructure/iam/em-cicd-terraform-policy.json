{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TerraformStateAccess",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket"],
      "Resource": ["arn:aws:s3:::ultravioleta-terraform-state", "arn:aws:s3:::ultravioleta-terraform-state/*"]
    },
    {
      "Sid": "TerraformECS",
      "Effect": "Allow",
      "Action": ["ecs:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformECR",
      "Effect": "Allow",
      "Action": ["ecr:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformNetworkALB",
      "Effect": "Allow",
      "Action": ["elasticloadbalancing:*", "ec2:Describe*", "ec2:*SecurityGroup*", "ec2:CreateTags", "ec2:DeleteTags"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformDNSCerts",
      "Effect": "Allow",
      "Action": ["route53:*", "acm:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformS3",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": ["arn:aws:s3:::em-production-*", "arn:aws:s3:::em-production-*/*"]
    },
    {
      "Sid": "TerraformCDN",
      "Effect": "Allow",
      "Action": ["cloudfront:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformSecrets",
      "Effect": "Allow",
      "Action": ["secretsmanager:*"],
      "Resource": ["arn:aws:secretsmanager:us-east-2:518898403364:secret:em/*"]
    },
    {
      "Sid": "TerraformIAM",
      "Effect": "Allow",
      "Action": ["iam:Get*", "iam:List*", "iam:PassRole", "iam:CreateRole", "iam:DeleteRole", "iam:*RolePolicy", "iam:TagRole", "iam:UntagRole"],
      "Resource": ["arn:aws:iam::518898403364:role/em-*", "arn:aws:iam::518898403364:role/ecsTaskExecutionRole", "arn:aws:iam::518898403364:policy/em-*"]
    },
    {
      "Sid": "TerraformLogs",
      "Effect": "Allow",
      "Action": ["logs:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformAPIGW",
      "Effect": "Allow",
      "Action": ["apigateway:*"],
      "Resource": ["arn:aws:apigateway:us-east-2::*"]
    },
    {
      "Sid": "TerraformLambda",
      "Effect": "Allow",
      "Action": ["lambda:*"],
      "Resource": ["arn:aws:lambda:us-east-2:518898403364:function:em-*"]
    },
    {
      "Sid": "TerraformLambdaEventSourceMapping",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateEventSourceMapping",
        "lambda:DeleteEventSourceMapping",
        "lambda:GetEventSourceMapping",
        "lambda:ListEventSourceMappings",
        "lambda:UpdateEventSourceMapping"
      ],
      "Resource": "*"
    },
    {
      "Sid": "TerraformSQS",
      "Effect": "Allow",
      "Action": ["sqs:*"],
      "Resource": ["arn:aws:sqs:us-east-2:518898403364:em-*"]
    },
    {
      "Sid": "TerraformExtra",
      "Effect": "Allow",
      "Action": ["dynamodb:*", "sns:*", "wafv2:*", "elasticfilesystem:*", "cloudwatch:*", "application-autoscaling:*"],
      "Resource": "*"
    }
  ]
}
