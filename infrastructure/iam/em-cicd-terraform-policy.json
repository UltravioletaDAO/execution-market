{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TerraformStateAccess",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:ListBucket"],
      "Resource": ["arn:aws:s3:::ultravioleta-terraform-state", "arn:aws:s3:::ultravioleta-terraform-state/*"]
    },
    {
      "Sid": "TerraformECSFull",
      "Effect": "Allow",
      "Action": ["ecs:*"],
      "Resource": "*",
      "Condition": {"StringEquals": {"aws:ResourceTag/Project": "execution-market"}}
    },
    {
      "Sid": "TerraformECSGlobal",
      "Effect": "Allow",
      "Action": ["ecs:DescribeTaskDefinition", "ecs:RegisterTaskDefinition", "ecs:DeregisterTaskDefinition", "ecs:ListTaskDefinitions", "ecs:ListClusters", "ecs:ListServices", "ecs:DescribeClusters", "ecs:DescribeServices"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformECR",
      "Effect": "Allow",
      "Action": ["ecr:*"],
      "Resource": ["arn:aws:ecr:us-east-2:518898403364:repository/em-production-*"]
    },
    {
      "Sid": "TerraformALB",
      "Effect": "Allow",
      "Action": ["elasticloadbalancing:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformRoute53",
      "Effect": "Allow",
      "Action": ["route53:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformACM",
      "Effect": "Allow",
      "Action": ["acm:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformS3",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": ["arn:aws:s3:::em-production-*", "arn:aws:s3:::em-production-*/*"]
    },
    {
      "Sid": "TerraformCloudFront",
      "Effect": "Allow",
      "Action": ["cloudfront:*"],
      "Resource": "*"
    },
    {
      "Sid": "TerraformSecrets",
      "Effect": "Allow",
      "Action": ["secretsmanager:GetSecretValue", "secretsmanager:DescribeSecret", "secretsmanager:ListSecrets", "secretsmanager:CreateSecret", "secretsmanager:UpdateSecret", "secretsmanager:PutSecretValue", "secretsmanager:DeleteSecret", "secretsmanager:TagResource"],
      "Resource": ["arn:aws:secretsmanager:us-east-2:518898403364:secret:em/*"]
    },
    {
      "Sid": "TerraformIAM",
      "Effect": "Allow",
      "Action": ["iam:GetRole", "iam:GetRolePolicy", "iam:ListRolePolicies", "iam:ListAttachedRolePolicies", "iam:PassRole", "iam:CreateRole", "iam:DeleteRole", "iam:PutRolePolicy", "iam:DeleteRolePolicy", "iam:AttachRolePolicy", "iam:DetachRolePolicy", "iam:TagRole", "iam:ListInstanceProfilesForRole"],
      "Resource": ["arn:aws:iam::518898403364:role/em-*", "arn:aws:iam::518898403364:role/ecsTaskExecutionRole"]
    },
    {
      "Sid": "TerraformLogs",
      "Effect": "Allow",
      "Action": ["logs:*"],
      "Resource": ["arn:aws:logs:us-east-2:518898403364:log-group:/ecs/em-*", "arn:aws:logs:us-east-2:518898403364:log-group:/ecs/em-*:*"]
    },
    {
      "Sid": "TerraformAPIGateway",
      "Effect": "Allow",
      "Action": ["apigateway:GET", "apigateway:POST", "apigateway:PUT", "apigateway:PATCH", "apigateway:DELETE"],
      "Resource": ["arn:aws:apigateway:us-east-2::*"]
    },
    {
      "Sid": "TerraformLambda",
      "Effect": "Allow",
      "Action": ["lambda:*"],
      "Resource": ["arn:aws:lambda:us-east-2:518898403364:function:em-*"]
    },
    {
      "Sid": "TerraformEC2Network",
      "Effect": "Allow",
      "Action": ["ec2:Describe*", "ec2:CreateSecurityGroup", "ec2:DeleteSecurityGroup", "ec2:AuthorizeSecurityGroupIngress", "ec2:RevokeSecurityGroupIngress", "ec2:AuthorizeSecurityGroupEgress", "ec2:RevokeSecurityGroupEgress", "ec2:CreateTags", "ec2:DeleteTags"],
      "Resource": "*"
    }
  ]
}
