      "proof_status_label",
      "forbidden_claims_preserved"
    ],
    "operator_review_status_allowed": ["reviewed"],
    "forbidden_claims_preserved_required": true
  },
  "review_gate_checks": [
    "question_match_or_deviation_explained",
    "source_type_explicit",
    "contradiction_or_refusal_preserved",
