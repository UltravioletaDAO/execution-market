  "proof_status_label": "planning_supported_needs_first_fixture",
  "fixture_goal": "Prove that one scoped municipal office question can be converted into a reviewed answer, explicit source type, redirect or confirmation result, and a safe next step without turning staff guidance into legal advice or worker-copyable doctrine.",
  "scenario_shape": {
    "municipal_objective": "Verify whether stale or ambiguous online guidance matches current counter/office reality.",
    "expected_case_pattern": "contradictory_online_guidance_or_unclear_window",
    "must_include": [
      "one exact primary question from intake",
      "one fallback clarification question if staff refuse or redirect",
      "source separation between observed signage, staff answer, and documented material",
      "operator-reviewed next step"
    ],
    "must_not_include": [
      "raw transcript as authority",
      "legal interpretation",
      "guaranteed acceptance or approval",
      "worker-copyable municipal doctrine"
    ]
  },
  "required_intake_fields": [
    "jurisdiction",
    "office_name_or_suspected_office",
    "office_address_if_known",
    "workflow_type",
    "exact_primary_question",
    "acceptable_answer_format",
    "urgency_window",
    "fallback_question_if_staff_refuse",
    "redirect_instruction",
    "customer_success_definition"
  ],
  "minimum_evidence": [
    "office_presence_or_open_state_observation_when_observable",
    "answer_source_note",
    "redirect_or_no_redirect_note",
    "operator_review_note"
  ],
  "outcome_status_options": [
    "verified_present",
    "verified_absent",
    "redirected",
    "blocked",
    "inconclusive"
  ],
  "source_type_options": [
    "observed",
    "heard_from_staff",
    "documented",
    "mixed"
  ],
  "customer_output_schema_draft": {
    "required_fields": [
      "offer",
