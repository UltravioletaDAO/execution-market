# =============================================================================
# Execution Market — MCP Server Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Supabase (Required)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Payment Configuration
# -----------------------------------------------------------------------------
# Payment mode: fase1 (direct settlement) | fase2 (on-chain escrow) | preauth (legacy)
EM_PAYMENT_MODE=fase1

# Escrow mode: platform_release | direct_release
EM_ESCROW_MODE=direct_release

# Platform fee percentage (default: 13%)
EM_PLATFORM_FEE=13

# Default payment network
X402_NETWORK=base

# Enabled payment networks (comma-separated)
EM_ENABLED_NETWORKS=base,ethereum,polygon,arbitrum,celo,monad,avalanche,optimism

# Fee model: credit_card | legacy
EM_FEE_MODEL=credit_card

# -----------------------------------------------------------------------------
# Wallet (Required for payment signing)
# -----------------------------------------------------------------------------
WALLET_PRIVATE_KEY=your-wallet-private-key

# Optional: Override settlement target address
# EM_SETTLEMENT_ADDRESS=

# Optional: Dedicated relay wallet for worker→agent feedback
# EM_REPUTATION_RELAY_KEY=

# Optional: Fase 5 operator address (required for fase2/fase5 mode)
# EM_PAYMENT_OPERATOR=

# -----------------------------------------------------------------------------
# Evidence Storage (S3 — set by ECS task definition via Terraform)
# -----------------------------------------------------------------------------
# S3 bucket name for evidence uploads (auto-set in ECS)
# EVIDENCE_BUCKET=em-prod-evidence-123456789
# CloudFront base URL for evidence delivery (auto-set in ECS)
# EVIDENCE_PUBLIC_BASE_URL=https://d1234abcdef.cloudfront.net

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
TESTING=false

# Optional: Test worker private key for E2E Golden Flow
# EM_WORKER_PRIVATE_KEY=
