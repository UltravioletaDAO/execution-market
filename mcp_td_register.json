{
  "family": "em-production-mcp-server",
  "taskRoleArn": "arn:aws:iam::YOUR_AWS_ACCOUNT_ID:role/em-production-ecs-task",
  "executionRoleArn": "arn:aws:iam::YOUR_AWS_ACCOUNT_ID:role/em-production-ecs-execution",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "mcp-server",
      "image": "YOUR_AWS_ACCOUNT_ID.dkr.ecr.us-east-2.amazonaws.com/em-production-mcp-server:ship-20260205-184732-hotfix-landing-profile",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "PORT",
          "value": "8000"
        },
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "ERC8004_NETWORK",
          "value": "base"
        },
        {
          "name": "EM_AGENT_ID",
          "value": "469"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "SUPABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/supabase:SUPABASE_URL::"
        },
        {
          "name": "SUPABASE_ANON_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/supabase:SUPABASE_ANON_KEY::"
        },
        {
          "name": "SUPABASE_SERVICE_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/supabase:SUPABASE_SERVICE_ROLE_KEY::"
        },
        {
          "name": "EM_ADMIN_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/admin-key"
        },
        {
          "name": "WALLET_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/x402:PRIVATE_KEY::"
        },
        {
          "name": "X402_NETWORK",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/x402:X402_NETWORK::"
        },
        {
          "name": "X402_RPC_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/x402:X402_RPC_URL::"
        },
        {
          "name": "X402_FACILITATOR_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/x402:FACILITATOR_URL::"
        },
        {
          "name": "EM_ESCROW_ADDRESS",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/x402:X402R_ESCROW::"
        },
        {
          "name": "USDC_ADDRESS",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/x402:USDC_ADDRESS::"
        },
        {
          "name": "EM_TREASURY_ADDRESS",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/commission:wallet_address::"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:YOUR_AWS_ACCOUNT_ID:secret:em/anthropic:ANTHROPIC_API_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/em-production/mcp-server",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "systemControls": []
    }
  ],
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512"
}
